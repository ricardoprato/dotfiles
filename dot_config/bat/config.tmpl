# bat config -- theme is rendered by chezmoi from the active dotfiles theme.
# Re-render on theme switch via: chezmoi apply ~/.config/bat/config
# (restart-bat hook does this automatically).

{{ $name := "" -}}
{{- $themeFile := joinPath .chezmoi.homeDir ".local/state/dotfiles/current-theme" -}}
{{- if stat $themeFile -}}
  {{- $name = trim (include $themeFile) -}}
{{- end -}}
{{- $batTheme := "OneHalfDark" -}}
{{- if eq $name "catppuccin" -}}{{- $batTheme = "Catppuccin Mocha" -}}
{{- else if eq $name "catppuccin-latte" -}}{{- $batTheme = "Catppuccin Latte" -}}
{{- else if eq $name "gruvbox" -}}{{- $batTheme = "gruvbox-dark" -}}
{{- else if eq $name "nord" -}}{{- $batTheme = "Nord" -}}
{{- else if or (eq $name "white") (eq $name "flexoki-light") -}}{{- $batTheme = "OneHalfLight" -}}
{{- end }}
--theme="{{ $batTheme }}"
--style numbers,changes

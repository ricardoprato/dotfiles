# Changes require a restart to take effect.

# Ensure Omarchy bins are in the path
export OMARCHY_PATH=$HOME/.local/share/omarchy
export PATH=$OMARCHY_PATH/bin:$PATH:$HOME/.local/bin

# Theming pipeline (decoupled from omarchy namespace)
export DOTFILES_PATH=$HOME/.local/share/dotfiles
export DOTFILES_STATE_PATH=$HOME/.local/state/dotfiles

# OCR languages for omarchy-capture-text-extraction (tesseract -l). Requires
# tesseract-data-<lang> installed per language.
export OMARCHY_OCR_LANGS=eng+spa

# Pin the weather widget location. wttr.in's IP geolocation is unreliable and
# intermittently misresolves this connection (Telecom Argentina) to the US,
# serving the wrong hemisphere's temperature. See chubin/wttr.in#599. City name
# or "lat,lon"; consumed by omarchy-weather-{status,icon}. Unset = auto geo-IP.
export OMARCHY_WEATHER_LOCATION=Buenos+Aires

# Set default terminal and editor
source ~/.config/uwsm/default

# Mise activation moved out of the session env: shims-at-front-of-PATH was
# breaking system scripts with `#!/usr/bin/env python3` (e.g. powerprofilesctl
# in /bin needs system Python's `gi` module — mise's bundled Python lacks it).
#
# Mise now activates per-shell via:
#   - fish: dot_config/fish/conf.d/mise.fish
#   - other shells: add `mise activate <shell> | source` to their rc.
#
# Inside a directory with .mise.toml the shell-level hook prepends the right
# tool versions. Non-interactive contexts (waybar, hyprland exec_on_start,
# systemd user services) see only the system PATH — which is what they want.

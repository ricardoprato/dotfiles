{
  "allow_postpone": false,
  "fade_in_break_screen": true,
  "fade_in_break_screen_duration": 1500,
  "long_break_duration": 60,
  "long_break_interval": 75,
  "long_breaks": [
    {
      "name": "Stand up and stretch your back and legs"
    },
    {
      "name": "Lean back at your seat and relax"
    },
    {
      "name": "Walk around and refill your water"
    },
    {
      "name": "Walk for a while"
    },
    {
      "name": "Step away from the screen and do a short mobility stretch"
    },
    {
      "name": "Rest your eyes and focus on distant objects"
    }
  ],
  "meta": {
    "config_version": "6.0.5"
  },
  "persist_state": false,
  "plugins": [
    {
      "enabled": true,
      "id": "donotdisturb",
      "settings": {
        "skip_break_windows": "",
        "take_break_windows": "",
        "unfullscreen": true,
        "while_on_battery": false
      },
      "version": "0.0.2"
    },
    {
      "enabled": true,
      "id": "notification",
      "version": "0.0.1"
    },
    {
      "enabled": true,
      "id": "audiblealert",
      "settings": {
        "post_break_alert": true,
        "pre_break_alert": true,
        "volume": 100
      },
      "version": "0.0.4"
    },
    {
      "enabled": true,
      "id": "trayicon",
      "settings": {
        "allow_disabling": true,
        "disable_options": [
          {
            "time": 30,
            "unit": "minute"
          },
          {
            "time": 1,
            "unit": "hour"
          },
          {
            "time": 2,
            "unit": "hour"
          },
          {
            "time": 3,
            "unit": "hour"
          }
        ],
        "show_long_time_in_tray": false,
        "show_time_in_tray": false
      },
      "version": "0.0.3"
    },
    {
      "enabled": true,
      "id": "smartpause",
      "settings": {
        "idle_time": 5,
        "postpone_if_active": false
      },
      "version": "0.0.3"
    },
    {
      "enabled": true,
      "id": "screensaver",
      "settings": {
        "command": "",
        "min_seconds": 3
      },
      "version": "0.0.2"
    },
    {
      "enabled": true,
      "id": "healthstats",
      "settings": {
        "statistics_reset_cron": "0 0 * * *"
      },
      "version": "0.0.3"
    },
    {
      "enabled": true,
      "id": "mediacontrol",
      "version": "0.0.1"
    },
    {
      "enabled": true,
      "id": "limitconsecutiveskipping",
      "settings": {
        "number_of_allowed_skips_in_a_row": 2
      },
      "version": "0.0.1"
    }
  ],
  "postpone_duration": 5,
  "postpone_unit": "minutes",
  "pre_break_warning_time": 10,
  "random_order": true,
  "short_break_duration": 15,
  "short_break_interval": 15,
  "short_breaks": [
    {
      "name": "Gently close your eyes"
    },
    {
      "name": "Take five slow, deep breaths"
    },
    {
      "name": "Rotate your eyes in clockwise direction"
    },
    {
      "name": "Relax your shoulders and drop them away from your ears"
    },
    {
      "name": "Blink your eyes"
    },
    {
      "name": "Stretch your neck gently from side to side"
    },
    {
      "name": "Roll your eyes a few times to each side"
    },
    {
      "name": "Check your posture and sit back comfortably"
    },
    {
      "name": "Rotate your eyes in counterclockwise direction"
    },
    {
      "name": "Unclench your jaw and relax your face"
    },
    {
      "name": "Focus on a point in the far distance"
    },
    {
      "name": "Stretch your wrists and fingers"
    },
    {
      "name": "Have some water"
    }
  ],
  "shortcut_disable_time": 2,
  "shortcut_postpone": 65,
  "shortcut_skip": 9,
  "strict_break": false
}


#!/bin/bash

# omarchy:summary=Restart an application — prefer user systemd unit, fall back to pkill+uwsm.
# omarchy:args=<application-name> [application-args...]

unit="$1.service"
if /usr/bin/systemctl --user list-unit-files --quiet "$unit" 2>/dev/null | /usr/bin/grep -q "^$unit"; then
  exec /usr/bin/systemctl --user restart "$unit"
fi

pkill -x "$1"
setsid uwsm-app -- "$@" >/dev/null 2>&1 &

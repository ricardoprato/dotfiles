#!/bin/bash

# omarchy:summary=Open the current theme's user background folder

CURRENT_THEME_NAME=$(cat "${DOTFILES_STATE_PATH:-$HOME/.local/state/dotfiles}/current-theme")
THEME_USER_BACKGROUNDS="$HOME/.config/dotfiles/backgrounds/$CURRENT_THEME_NAME"

mkdir -p "$THEME_USER_BACKGROUNDS"
nautilus "$THEME_USER_BACKGROUNDS"

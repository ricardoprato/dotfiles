#!/bin/bash

# omarchy:summary=Open the Omarchy background switcher
# omarchy:group=theme
# omarchy:name=bg-switcher
# omarchy:aliases=omarchy background

DOTFILES_STATE_PATH=${DOTFILES_STATE_PATH:-$HOME/.local/state/dotfiles}
theme_name=$(cat "$DOTFILES_STATE_PATH/current-theme" 2>/dev/null)
current_background=$(readlink -f "$DOTFILES_STATE_PATH/current-background" 2>/dev/null)

omarchy-menu-images \
  --selected "$current_background" \
  "$DOTFILES_STATE_PATH/current-theme-dir/backgrounds" \
  "$HOME/.config/dotfiles/backgrounds/$theme_name"

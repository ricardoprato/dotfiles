#!/bin/bash

# omarchy:summary=Cache background switcher thumbnails for the current theme

DOTFILES_STATE_PATH=${DOTFILES_STATE_PATH:-$HOME/.local/state/dotfiles}
theme_name=$(cat "$DOTFILES_STATE_PATH/current-theme" 2>/dev/null)

omarchy-menu-images \
  --cache-only \
  "$DOTFILES_STATE_PATH/current-theme-dir/backgrounds" \
  "$HOME/.config/dotfiles/backgrounds/$theme_name"

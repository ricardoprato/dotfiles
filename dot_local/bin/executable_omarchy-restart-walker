#!/bin/bash

# omarchy:summary=Restart Walker (D-Bus activation) and Elephant backend

if systemctl --user is-enabled elephant.service &>/dev/null; then
  systemctl --user restart elephant.service
fi

# Walker in this fork has no systemd unit — runs via D-Bus activation
# from ~/.config/walker/default/walker.desktop. Kill the daemon so the
# next request picks up fresh config/CSS instead of reusing the cached
# theme tokens from the previous theme.
pkill -x walker 2>/dev/null
sleep 0.2
setsid -f walker --gapplication-service </dev/null >/dev/null 2>&1

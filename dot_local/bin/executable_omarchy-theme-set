#!/bin/bash

# omarchy:summary=Apply a theme by name (renders per-app theme files)
# omarchy:args=<theme-name>
# omarchy:examples=omarchy theme list | omarchy theme set "Tokyo Night"

if [[ -z $1 ]]; then
  echo "Usage: omarchy-theme-set <theme-name>"
  exit 1
fi

DOTFILES_PATH=${DOTFILES_PATH:-$HOME/.local/share/dotfiles}
DOTFILES_STATE_PATH=${DOTFILES_STATE_PATH:-$HOME/.local/state/dotfiles}

THEMES_PATH="$DOTFILES_PATH/themes"
USER_THEMES_PATH="$HOME/.config/dotfiles/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

# Resolve theme dir (user override beats bundled)
if [[ -d $USER_THEMES_PATH/$THEME_NAME ]]; then
  THEME_DIR="$USER_THEMES_PATH/$THEME_NAME"
elif [[ -d $THEMES_PATH/$THEME_NAME ]]; then
  THEME_DIR="$THEMES_PATH/$THEME_NAME"
else
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

mkdir -p "$DOTFILES_STATE_PATH"

# Point state at the active theme's source dir (renderer + bg scripts read from here)
ln -snf "$THEME_DIR" "$DOTFILES_STATE_PATH/current-theme-dir"
echo "$THEME_NAME" >"$DOTFILES_STATE_PATH/current-theme"

# Generate colors.toml from alacritty.toml if theme is missing colors.toml
if [[ ! -f $THEME_DIR/colors.toml && -f $THEME_DIR/alacritty.toml ]]; then
  omarchy-theme-colors-from-alacritty "$THEME_DIR"
fi

# Render all templates → per-app destinations
omarchy-theme-set-templates

# Background
if [[ $OMARCHY_THEME_SKIP_BACKGROUND != "1" ]]; then
  omarchy-theme-bg-next
fi

# Reload pull-pattern consumers
if pgrep -x waybar >/dev/null; then
  omarchy-restart-waybar
fi
omarchy-restart-swayosd
omarchy-restart-terminal
omarchy-restart-hyprctl
omarchy-restart-btop
restart-bat
omarchy-restart-opencode
omarchy-restart-mako
omarchy-restart-walker
omarchy-restart-helix

# Push-pattern handlers (apps without include/source mechanism, plus foot live-OSC update)
omarchy-theme-set-foot
omarchy-theme-set-gnome
omarchy-theme-set-browser
omarchy-theme-set-vscode
omarchy-theme-set-obsidian
omarchy-theme-set-keyboard

# Hook + bg cache
omarchy-hook theme-set "$THEME_NAME" >/dev/null
omarchy-theme-bg-cache >/dev/null 2>&1 &
